# Firebase Web API キー（サーバサイドの Identity Toolkit REST 認証で使用。ブラウザには公開しない）
FIREBASE_API_KEY=your-firebase-web-api-key

# 許可するメールアドレス（カンマ区切り、空の場合は全ユーザー許可）
ALLOWED_USER_EMAILS=your-email@example.com

# セッションcookie署名用のランダム文字列（32文字以上推奨）
AUTH_SECRET=your-random-secret-key-here

# Firestore接続（本番環境ではGCP Application Default Credentials を使用）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ローカル開発でFirestore Emulatorを使用する場合（コメントを外す）
# FIRESTORE_EMULATOR_HOST=localhost:8080

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 相互自動登録（日本語⇄英文 自動生成）用 Gemini API キー
# 未設定の場合、自動生成は無効化され手動入力のみになります
GEMINI_API_KEY=your-gemini-api-key
# 任意: 使用する Gemini モデル（既定 gemini-2.0-flash）
# GEMINI_MODEL=gemini-2.0-flash
