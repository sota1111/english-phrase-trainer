# ===================================
# アプリケーション設定
# ===================================

# Next.js環境
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=English Phrase Trainer

# ===================================
# Firestore設定
# ===================================

# GCPプロジェクトID（本番Firestoreまたはエミュレーター使用時に必要）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ===================================
# Firestore Emulator設定（ローカル開発用）
# ===================================
# エミュレーターを使用する場合は以下のコメントを外す
# FIRESTORE_EMULATOR_HOST=localhost:8080
