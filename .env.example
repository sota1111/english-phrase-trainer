# Firebase Web API キー（サーバサイドの Identity Toolkit REST 認証で使用。ブラウザには公開しない）
# Cloud Run本番環境ではSecret Manager管理推奨
FIREBASE_API_KEY=your-firebase-web-api-key

# アプリのベースURL（デプロイ後のURL、または localhost:3000）
NEXT_PUBLIC_BASE_URL=https://english-phrase-trainer-xxxx.a.run.app

# 許可するメールアドレス（カンマ区切り、空の場合は全ユーザー許可）
# Cloud Run本番環境ではSecret Manager管理推奨
ALLOWED_USER_EMAILS=your-email@example.com

# セッションcookie署名用のランダム文字列（32文字以上推奨）
# Cloud Run本番環境ではSecret Manager管理 (secret name: english-trainer-auth-secret)
AUTH_SECRET=your-random-secret-key-here

# ===================================
# GCP / Cloud Run デプロイ設定
# ===================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1
CLOUD_RUN_SERVICE_NAME=english-phrase-trainer
ARTIFACT_REGISTRY_REPOSITORY=english-phrase-registry
IMAGE_NAME=english-phrase-trainer

# 相互自動登録（日本語⇄英文 自動生成）用 Anthropic API キー
# 未設定の場合、自動生成は無効化され手動入力のみになります
ANTHROPIC_API_KEY=your-anthropic-api-key
