# Firebase クライアント設定（Firebase Console > プロジェクト設定 > アプリ から取得）
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# 許可するメールアドレス（カンマ区切り、空の場合は全ユーザー許可）
ALLOWED_USER_EMAILS=your-email@example.com

# セッションcookie署名用のランダム文字列（32文字以上推奨）
AUTH_SECRET=your-random-secret-key-here

# Firestore接続（本番環境ではGCP Application Default Credentials を使用）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ローカル開発でFirestore Emulatorを使用する場合（コメントを外す）
# FIRESTORE_EMULATOR_HOST=localhost:8080

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 相互自動登録（日本語⇄英文 自動生成）用 Anthropic API キー
# 未設定の場合、自動生成は無効化され手動入力のみになります
ANTHROPIC_API_KEY=your-anthropic-api-key
